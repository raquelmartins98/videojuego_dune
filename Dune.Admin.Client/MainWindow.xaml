<Window x:Class="Dune.Admin.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Dune.Admin.Client.ViewModels"
        xmlns:conv="clr-namespace:Dune.Admin.Client.Converters"
        Title="DUNE: ARRAGAN DOMINION" 
        Height="700" Width="1200"
        MinHeight="600" MinWidth="1000"
        Background="#0D0D0D"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        ResizeMode="CanResizeWithGrip">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <conv:TipoEventoToColorConverter x:Key="TipoEventoToColor"/>
        <conv:TipoRecursoToDisplayNameConverter x:Key="TipoRecursoToDisplayName"/>
        <conv:TipoTerrenoToColorConverter x:Key="TipoTerrenoToColor"/>
        
        <!-- DUNE COLOR PALETTE -->
        <Style x:Key="DuneButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2118"/>
            <Setter Property="Foreground" Value="#C9A227"/>
            <Setter Property="BorderBrush" Value="#C9A227"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A3728"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C9A227"/>
                                <Setter Property="Foreground" Value="#0D0D0D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DunePanel" TargetType="Border">
            <Setter Property="Background" Value="#1A1410"/>
            <Setter Property="BorderBrush" Value="#4A3728"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15"/>
        </Style>

        <Style x:Key="DuneTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C9A227"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="DuneLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B7355"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="DuneListBox" TargetType="ListBox">
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="BorderBrush" Value="#4A3728"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#8B7355"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="DuneListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#D4AF37"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#2D2118"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2D2118"/>
                    <Setter Property="Foreground" Value="#C9A227"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1410"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Background" Value="#2D2118"/>
            <Setter Property="Foreground" Value="#C9A227"/>
            <Setter Property="BorderBrush" Value="#4A3728"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- MENU PRINCIPAL -->
        <Grid x:Name="MenuPrincipal" Visibility="Visible">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1A0A00" Offset="0"/>
                    <GradientStop Color="#2D1508" Offset="0.3"/>
                    <GradientStop Color="#4A2810" Offset="0.5"/>
                    <GradientStop Color="#2D1508" Offset="0.7"/>
                    <GradientStop Color="#1A0A00" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Canvas>
                <Polygon Points="0,500 150,250 300,500" Fill="#3D2010" Opacity="0.6"/>
                <Polygon Points="0,500 100,300 200,500" Fill="#2D1508" Opacity="0.8"/>
                <Polygon Points="150,500 350,200 550,500" Fill="#4A2810" Opacity="0.5"/>
                <Polygon Points="200,500 380,280 520,500" Fill="#3D2010" Opacity="0.7"/>
                <Polygon Points="350,500 500,150 650,500" Fill="#5A3020" Opacity="0.6"/>
                <Polygon Points="400,500 520,220 620,500" Fill="#4A2810" Opacity="0.8"/>
                <Polygon Points="550,500 700,250 850,500" Fill="#3D2010" Opacity="0.5"/>
                <Polygon Points="600,500 750,300 850,500" Fill="#2D1508" Opacity="0.7"/>
                <Ellipse Width="80" Height="80" Canvas.Left="460" Canvas.Top="50" Fill="#C9A227" Opacity="0.3"/>
                <Ellipse Width="60" Height="60" Canvas.Left="470" Canvas.Top="60" Fill="#D4AF37" Opacity="0.5"/>
                <Rectangle Width="1200" Height="2" Canvas.Top="480" Fill="#8B7355" Opacity="0.3"/>
                <Rectangle Width="900" Height="1" Canvas.Top="490" Fill="#8B7355" Opacity="0.2"/>
            </Canvas>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈" Foreground="#8B7355" FontFamily="Consolas" FontSize="14" TextAlignment="Center" Opacity="0.5"/>
                    <TextBlock Text="DUNE" Foreground="#C9A227" FontFamily="Consolas" FontSize="72" FontWeight="Bold" TextAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#C9A227" BlurRadius="30" ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="ARRAGAN DOMINION" Foreground="#D4AF37" FontFamily="Consolas" FontSize="24" TextAlignment="Center"/>
                    <TextBlock Text="◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈◈" Foreground="#8B7355" FontFamily="Consolas" FontSize="14" TextAlignment="Center" Opacity="0.5"/>
                </StackPanel>

                <StackPanel>
                    <Button Content="▸ NUEVA PARTIDA" Style="{StaticResource DuneButton}" Click="NuevaPartida_Click"/>
                    <Button Content="▸ CARGAR PARTIDA" Style="{StaticResource DuneButton}" Click="IrACargar_Click"/>
                    <Button Content="▸ MANUAL" Style="{StaticResource DuneButton}" Click="IrAManual_Click"/>
                    <Button Content="▸ OPCIONES" Style="{StaticResource DuneButton}" Click="IrAOpciones_Click"/>
                    <Button Content="▸ CREDITOS" Style="{StaticResource DuneButton}" Click="IrACreditos_Click"/>
                    <Button Content="▸ [TEST GAME OVER]" Style="{StaticResource DuneButton}" Click="TestGameOver_Click" Foreground="#FF4500"/>
                    <Button Content="▸ SALIR" Style="{StaticResource DuneButton}" Foreground="#FF4500" BorderBrush="#FF4500" Click="Salir_Click"/>
                </StackPanel>

                <TextBlock Text="v1.0 - Arrakis System" Foreground="#8B7355" FontFamily="Consolas" FontSize="12" TextAlignment="Center" Margin="0,40,0,0" Opacity="0.5"/>
            </StackPanel>
        </Grid>

        <!-- PAGINA JUEGO PRINCIPAL -->
        <Grid x:Name="PaginaJuego" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Border Grid.Row="0" Style="{StaticResource DunePanel}" Margin="10,10,10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="◈ DUNE: ARRAGAN DOMINION ◈" Style="{StaticResource DuneTitle}" FontSize="24"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#2D2118" BorderBrush="#C9A227" BorderThickness="1" Padding="10,5" Margin="5,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ESPECIA: " Style="{StaticResource DuneLabel}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding EspeciaTotal}" Foreground="#C9A227" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#2D2118" BorderBrush="#00CED1" BorderThickness="1" Padding="10,5" Margin="5,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="AGUA: " Style="{StaticResource DuneLabel}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AguaTotal}" Foreground="#00CED1" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#2D2118" BorderBrush="#228B22" BorderThickness="1" Padding="10,5" Margin="5,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="CRIATURAS: " Style="{StaticResource DuneLabel}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CriaturasVivas}" Foreground="#228B22" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
            
            <Border Grid.Row="1" Style="{StaticResource DunePanel}" Margin="10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="◆ PANEL DE CONTROL ◆" Style="{StaticResource DuneTitle}" VerticalAlignment="Center"/>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="MENU" Style="{StaticResource DuneButton}" Background="#4A3728" Click="IrAMenu_Click"/>
                        <Button Content="BESTIARIO" Style="{StaticResource DuneButton}" Background="#1A1410" Click="IrABestiario_Click"/>
                        <Button Content="OPCIONES" Style="{StaticResource DuneButton}" Background="#4A3728" Click="IrAOpciones_Click"/>
                        <Button Content="NUEVA PARTIDA" Style="{StaticResource DuneButton}" Background="#228B22" Command="{Binding NuevaPartidaCommand}"/>
                        <Button Content="CARGAR" Style="{StaticResource DuneButton}" Background="#1A1410" Click="IrACargar_Click"/>
                        <Button Content="GUARDAR" Style="{StaticResource DuneButton}" Background="#1A1410" Click="IrAGuardar_Click"/>
                        <Button Content="◈ EJECUTAR RONDA ◈" Style="{StaticResource DuneButton}" Background="#C9A227" Foreground="#0D0D0D" Command="{Binding EjecutarRondaCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <Grid Grid.Row="2" Margin="10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Style="{StaticResource DunePanel}" Margin="0,0,5,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="◆ CRIATURAS ◆" Style="{StaticResource DuneTitle}" Foreground="#FF4500"/>
                        </StackPanel>
                        
                        <ListBox Grid.Row="1" Style="{StaticResource DuneListBox}" ItemsSource="{Binding Criaturas}" ItemContainerStyle="{StaticResource DuneListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="3">
                                        <TextBlock Text="{Binding Nombre}" FontWeight="Bold" FontSize="12" Foreground="#C9A227"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="VIDA: " Style="{StaticResource DuneLabel}"/>
                                            <TextBlock Text="{Binding Vida}" Foreground="#228B22"/>
                                            <TextBlock Text="/" Foreground="#4A3728"/>
                                            <TextBlock Text="{Binding VidaMaxima}" Foreground="#4A3728"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="POSICION: (" Style="{StaticResource DuneLabel}"/>
                                            <TextBlock Text="{Binding PosicionX}" Foreground="#D4AF37"/>
                                            <TextBlock Text="," Style="{StaticResource DuneLabel}"/>
                                            <TextBlock Text="{Binding PosicionY}" Foreground="#D4AF37"/>
                                            <TextBlock Text=")" Style="{StaticResource DuneLabel}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
                
                <Border Grid.Column="1" Style="{StaticResource DunePanel}" Margin="0,0,5,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                         
                        <Expander Grid.Row="0" Header="▸ VER MAPA Y LEYENDA" IsExpanded="False" Foreground="#C9A227" FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,10">
                            <Border Background="#1A1410" BorderBrush="#4A3728" BorderThickness="1" Padding="10" Margin="0,5,0,0">
                                <StackPanel>
                                    <Border Width="220" Height="220" Background="#1A1410" BorderBrush="#C9A227" BorderThickness="2" HorizontalAlignment="Center">
                                        <Canvas x:Name="MapaVisual"/>
                                    </Border>
                                    
                                    <Border Background="#2D2118" BorderBrush="#C9A227" BorderThickness="1" Padding="8" Margin="0,10,0,0" HorizontalAlignment="Center">
                                        <StackPanel>
                                            <TextBlock Text="=== LEYENDA ===" Foreground="#C9A227" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            
                                            <TextBlock Text="ENTIDADES:" Foreground="#FFD700" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,1">
                                                <Ellipse Width="10" Height="10" Fill="Red" Stroke="DarkRed" Margin="0,0,4,0"/>
                                                <TextBlock Text="Criatura" Foreground="#D4AF37" FontSize="9"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                                                <Ellipse Width="10" Height="10" Fill="#00CED1" Stroke="White" Margin="0,0,4,0"/>
                                                <TextBlock Text="Enclave" Foreground="#D4AF37" FontSize="9"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,1,0,4">
                                                <Rectangle Width="10" Height="10" Fill="#32CD32" Margin="0,0,4,0"/>
                                                <TextBlock Text="Recurso" Foreground="#D4AF37" FontSize="9"/>
                                            </StackPanel>
                                            
                                            <TextBlock Text="TERRENO:" Foreground="#FFD700" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <WrapPanel HorizontalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,6,1">
                                                    <Rectangle Width="10" Height="10" Fill="#C29A6C" Margin="0,0,2,0"/>
                                                    <TextBlock Text="Desierto" Foreground="#8B7355" FontSize="8"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,6,1">
                                                    <Rectangle Width="10" Height="10" Fill="#8B4513" Margin="0,0,2,0"/>
                                                    <TextBlock Text="Roca" Foreground="#8B7355" FontSize="8"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,6,1">
                                                    <Rectangle Width="10" Height="10" Fill="#D2B48C" Margin="0,0,2,0"/>
                                                    <TextBlock Text="Arena" Foreground="#8B7355" FontSize="8"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,6,1">
                                                    <Rectangle Width="10" Height="10" Fill="#C9A227" Margin="0,0,2,0"/>
                                                    <TextBlock Text="Melange" Foreground="#8B7355" FontSize="8"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,6,1">
                                                    <Rectangle Width="10" Height="10" Fill="#FF69B4" Margin="0,0,2,0"/>
                                                    <TextBlock Text="Esp.Rosa" Foreground="#8B7355" FontSize="8"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,1">
                                                    <Rectangle Width="10" Height="10" Fill="#800080" Margin="0,0,2,0"/>
                                                    <TextBlock Text="Esp.Negra" Foreground="#8B7355" FontSize="8"/>
                                                </StackPanel>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Expander>
                        
                        <StackPanel Grid.Row="1">
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="◆ ENCLAVES ◆" Style="{StaticResource DuneTitle}"/>
                                <TextBlock Text="Shai-Hulud - Ciudades del Desierto" Style="{StaticResource DuneLabel}"/>
                            </StackPanel>
                            
                            <ListBox Style="{StaticResource DuneListBox}" ItemsSource="{Binding Enclaves}" ItemContainerStyle="{StaticResource DuneListBoxItem}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="3">
                                            <TextBlock Text="{Binding Nombre}" FontWeight="Bold" FontSize="12" Foreground="#C9A227"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="VISITANTES: " Style="{StaticResource DuneLabel}"/>
                                                <TextBlock Text="{Binding VisitantesActuales}" Foreground="#D4AF37"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="NIVEL: " Style="{StaticResource DuneLabel}"/>
                                                <TextBlock Text="{Binding Nivel}" Foreground="#00CED1"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <Border Grid.Column="2" Style="{StaticResource DunePanel}" Margin="0,0,5,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                         
                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="◆ RECURSOS ◆" Style="{StaticResource DuneTitle}" Foreground="#00CED1"/>
                            <TextBlock Text="Melange, Especia Rosa y Especia Negra" Style="{StaticResource DuneLabel}"/>
                        </StackPanel>
                        
                        <ListBox Grid.Row="1" Style="{StaticResource DuneListBox}" ItemsSource="{Binding RecursosPaginados}" ItemContainerStyle="{StaticResource DuneListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="3">
                                        <TextBlock Text="{Binding Tipo, Converter={StaticResource TipoRecursoToDisplayName}}" FontWeight="Bold" FontSize="13" Foreground="#C9A227"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="TOTAL: " Style="{StaticResource DuneLabel}"/>
                                            <TextBlock Text="{Binding CantidadTotal}" FontWeight="Bold" FontSize="14" Foreground="#D4AF37"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="YACIMIENTOS: " Style="{StaticResource DuneLabel}"/>
                                            <TextBlock Text="{Binding CantidadYacimientos}" Foreground="#D4AF37"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Button Content="◀" Style="{StaticResource DuneButton}" Padding="10,5" Click="PaginaAnteriorRecursos_Click"/>
                            <TextBlock Text="{Binding PaginaRecursosTexto}" VerticalAlignment="Center" Foreground="#C9A227" FontFamily="Consolas" Margin="10,0"/>
                            <Button Content="▶" Style="{StaticResource DuneButton}" Padding="10,5" Click="PaginaSiguienteRecursos_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <Border Grid.Column="3" Style="{StaticResource DunePanel}" Margin="5,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Margin="0,0,0,5">
                            <TextBlock Text="◆ REGISTRO DE EVENTOS ◆" Style="{StaticResource DuneTitle}" Foreground="#228B22"/>
                        </StackPanel>
                        
                        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
                            <Button Content="TODOS" Style="{StaticResource DuneButton}" Padding="6,2" Margin="1" FontSize="8" Command="{Binding CambiarFiltroCommand}" CommandParameter="TODOS"/>
                            <Button Content="COMBATE" Style="{StaticResource DuneButton}" Padding="6,2" Margin="1" FontSize="8" Command="{Binding CambiarFiltroCommand}" CommandParameter="CriaturaAtaco"/>
                            <Button Content="MOV." Style="{StaticResource DuneButton}" Padding="6,2" Margin="1" FontSize="8" Command="{Binding CambiarFiltroCommand}" CommandParameter="CriaturaMovio"/>
                            <Button Content="RECURSO" Style="{StaticResource DuneButton}" Padding="6,2" Margin="1" FontSize="8" Command="{Binding CambiarFiltroCommand}" CommandParameter="RecursoExtraido"/>
                            <Button Content="NACER" Style="{StaticResource DuneButton}" Padding="6,2" Margin="1" FontSize="8" Command="{Binding CambiarFiltroCommand}" CommandParameter="InstalacionConstruida"/>
                            <Button Content="GANAN." Style="{StaticResource DuneButton}" Padding="6,2" Margin="1" FontSize="8" Command="{Binding CambiarFiltroCommand}" CommandParameter="Ganancias"/>
                        </WrapPanel>
                        
                        <ListBox Grid.Row="2" Style="{StaticResource DuneListBox}" ItemsSource="{Binding Eventos}" ItemContainerStyle="{StaticResource DuneListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2D2118" BorderThickness="0,0,0,1" Padding="5,3">
                                        <TextBlock Text="{Binding Descripcion}" TextWrapping="Wrap" FontSize="12" FontFamily="Consolas" Foreground="{Binding Tipo, Converter={StaticResource TipoEventoToColor}}"/>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <Grid Grid.Row="3" Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0" Content="◀" Style="{StaticResource DuneButton}" Padding="15,5" HorizontalAlignment="Left" Command="{Binding PaginaAnteriorCommand}"/>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding PaginaTexto}" Foreground="#D4AF37" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text=" | " Foreground="#4A3728" FontSize="12"/>
                                <TextBlock Text="{Binding TotalEventosTexto}" Foreground="#8B7355" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <Button Grid.Column="2" Content="▶" Style="{StaticResource DuneButton}" Padding="15,5" HorizontalAlignment="Right" Command="{Binding PaginaSiguienteCommand}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
            
            <Border Grid.Row="3" Style="{StaticResource DunePanel}" Margin="10,5,10,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="◆ " Foreground="#C9A227"/>
                    <TextBlock Text="{Binding MensajeEstado}" Foreground="#D4AF37"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- PAGINA CARGAR PARTIDA -->
        <Grid x:Name="PaginaCargar" Visibility="Collapsed" Background="#0D0D0D">
            <Grid Margin="50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

