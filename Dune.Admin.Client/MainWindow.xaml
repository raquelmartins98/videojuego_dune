<Window x:Class="Dune.Admin.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Dune.Admin.Client.ViewModels"
        Title="DUNE: ARRAGAN DOMINION" 
        Height="800" Width="1200"
        Background="#0D0D0D"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <!-- DUNE COLOR PALETTE -->
        <!-- #0D0D0D - Obsidian Black (fondo profundo) -->
        <!-- #1A1410 - Arena Oscura -->
        <!-- #2D2118 - Arena Profunda -->
        <!-- #C9A227 - Oro Imperial (especia/énfasis) -->
        <!-- #D4AF37 - OroClaro -->
        <!-- #8B7355 - Arena Clara -->
        <!-- #4A3728 - Roca del Desierto -->
        <!-- #00CED1 - Agua/Tecnología Fremen -->
        <!-- #FF4500 - Peligro (Sardaukar) -->
        <!-- #228B22 - Oasis (verde) -->
        
        <Style x:Key="DuneButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2118"/>
            <Setter Property="Foreground" Value="#C9A227"/>
            <Setter Property="BorderBrush" Value="#C9A227"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A3728"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C9A227"/>
                                <Setter Property="Foreground" Value="#0D0D0D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DunePanel" TargetType="Border">
            <Setter Property="Background" Value="#1A1410"/>
            <Setter Property="BorderBrush" Value="#4A3728"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
        
        <Style x:Key="DuneTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C9A227"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
        
        <Style x:Key="DuneLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B7355"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        
        <Style x:Key="DuneValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D4AF37"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        
        <Style x:Key="DuneListBox" TargetType="ListBox">
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="BorderBrush" Value="#4A3728"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#8B7355"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        
        <Style x:Key="DuneListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#D4AF37"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#2D2118"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2D2118"/>
                    <Setter Property="Foreground" Value="#C9A227"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1410"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="DangerText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF4500"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <Style x:Key="SuccessText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#228B22"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- HEADER - Logo y Estado -->
        <Border Grid.Row="0" Style="{StaticResource DunePanel}" Margin="10,10,10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="◈ DUNE: ARRAGAN DOMINION ◈" Style="{StaticResource DuneTitle}" FontSize="24"/>
                    <TextBlock Text="SISTEMA DE ADMINISTRACION DISTRIBUIDA - ARRANGAN SYSTEM" Style="{StaticResource DuneLabel}" Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ESTADO: " Style="{StaticResource DuneLabel}" VerticalAlignment="Center"/>
                    <Ellipse Width="12" Height="12" Fill="#228B22" Margin="5,0"/>
                    <TextBlock Text="OPERATIVO" Style="{StaticResource SuccessText}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- PANEL DE CONTROL -->
        <Border Grid.Row="1" Style="{StaticResource DunePanel}" Margin="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="◆ PANEL DE CONTROL ◆" Style="{StaticResource DuneTitle}" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="NUEVA PARTIDA" Style="{StaticResource DuneButton}" Background="#228B22" Command="{Binding NuevaPartidaCommand}"/>
                    <Button Content="CARGAR" Style="{StaticResource DuneButton}" Background="#1A1410" Command="{Binding CargarPartidaCommand}"/>
                    <Button Content="GUARDAR" Style="{StaticResource DuneButton}" Background="#1A1410" Command="{Binding GuardarPartidaCommand}"/>
                    <Button Content="◈ EJECUTAR RONDA ◈" Style="{StaticResource DuneButton}" Background="#C9A227" Foreground="#0D0D0D" Command="{Binding EjecutarRondaCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Row="2" Margin="10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>
            
            <!-- PANEL CRIATURAS -->
            <Border Grid.Column="0" Style="{StaticResource DunePanel}" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="◆ CRIATURAS DE ARENA ◆" Style="{StaticResource DuneTitle}" Foreground="#FF4500"/>
                        <TextBlock Text="Shai-Hulud - Gusanos del Desierto" Style="{StaticResource DuneLabel}"/>
                    </StackPanel>
                    
                    <ListBox Grid.Row="1" Style="{StaticResource DuneListBox}" 
                             ItemsSource="{Binding Criaturas}" 
                             ItemContainerStyle="{StaticResource DuneListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="3">
                                    <TextBlock Text="{Binding Nombre}" FontWeight="Bold" FontSize="13"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="MEDIO: " Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding Medio}" Foreground="#FF4500"/>
                                        <TextBlock Text=" | ROL: " Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding Rol}" Foreground="#C9A227"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="EDAD ADULTA: " Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding EdadAdulta}" Style="{StaticResource DuneValue}"/>
                                        <TextBlock Text=" | APETITO: " Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding ApetitoBase}" Foreground="#FF4500"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="VIDA: " Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding Vida}" Style="{StaticResource DuneValue}"/>
                                        <TextBlock Text=" | POS: (" Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding PosicionX}" Foreground="#00CED1"/>
                                        <TextBlock Text="," Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding PosicionY}" Foreground="#00CED1"/>
                                        <TextBlock Text=")" Style="{StaticResource DuneLabel}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            
            <!-- PANEL ENCLAVES -->
            <Border Grid.Column="1" Style="{StaticResource DunePanel}" Margin="5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="◆ ENCLAVES ◆" Style="{StaticResource DuneTitle}" Foreground="#00CED1"/>
                        <TextBlock Text="Ciudades y Asentamientos de Arrakan" Style="{StaticResource DuneLabel}"/>
                    </StackPanel>
                    
                    <ListBox Grid.Row="1" Style="{StaticResource DuneListBox}"
                             ItemsSource="{Binding Enclaves}"
                             ItemContainerStyle="{StaticResource DuneListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="3">
                                    <TextBlock Text="{Binding Nombre}" FontWeight="Bold" FontSize="11"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="TIPO: " Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding Tipo}" Foreground="#00CED1"/>
                                        <TextBlock Text=" | HECTAREAS: " Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding Hectareas}" Foreground="#C9A227"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="VISITANTES: " Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding VisitantesActuales}" Style="{StaticResource DuneValue}"/>
                                        <TextBlock Text=" | MES: " Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding VisitantesMesEnclave}" Foreground="#228B22"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="PRECIO ENTRADA: " Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding PrecioEntrada}" Foreground="#FF4500"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            
            <!-- PANEL RECURSOS -->
            <Border Grid.Column="2" Style="{StaticResource DunePanel}" Margin="5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="◆ RECURSOS ◆" Style="{StaticResource DuneTitle}" Foreground="#C9A227"/>
                        <TextBlock Text="Especia, Agua y Suministros" Style="{StaticResource DuneLabel}"/>
                    </StackPanel>
                    
                    <ListBox Grid.Row="1" Style="{StaticResource DuneListBox}"
                             ItemsSource="{Binding Recursos}"
                             ItemContainerStyle="{StaticResource DuneListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="3">
                                    <TextBlock Text="{Binding Tipo}" FontWeight="Bold" FontSize="13" Foreground="#C9A227"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="CANTIDAD: " Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding Cantidad}" Style="{StaticResource DuneValue}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="POSICION: (" Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding PosicionX}" Foreground="#D4AF37"/>
                                        <TextBlock Text="," Style="{StaticResource DuneLabel}"/>
                                        <TextBlock Text="{Binding PosicionY}" Foreground="#D4AF37"/>
                                        <TextBlock Text=")" Style="{StaticResource DuneLabel}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            
            <!-- PANEL EVENTOS -->
            <Border Grid.Column="3" Style="{StaticResource DunePanel}" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="◆ REGISTRO DE EVENTOS ◆" Style="{StaticResource DuneTitle}" Foreground="#228B22"/>
                        <TextBlock Text="Actividad del Sistema de Simulacion" Style="{StaticResource DuneLabel}"/>
                    </StackPanel>
                    
                    <ListBox Grid.Row="1" Style="{StaticResource DuneListBox}"
                             ItemsSource="{Binding Eventos}"
                             ItemContainerStyle="{StaticResource DuneListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2">
                                    <TextBlock Text="{Binding Descripcion}" TextWrapping="Wrap" FontSize="11" Foreground="#D4AF37"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="[" Foreground="#4A3728"/>
                                        <TextBlock Text="{Binding Tipo}" FontSize="9" Foreground="#8B7355"/>
                                        <TextBlock Text="]" Foreground="#4A3728"/>
                                        <TextBlock Text=" " Foreground="#4A3728"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" FontSize="9" Foreground="#4A3728"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
        
        <!-- FOOTER - Estado del Sistema -->
        <Border Grid.Row="3" Style="{StaticResource DunePanel}" Margin="10,5,10,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="◆ " Foreground="#C9A227"/>
                    <TextBlock Text="{Binding MensajeEstado}" Foreground="#D4AF37" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="SALIR" Style="{StaticResource DuneButton}" Background="#4A3728" Command="{Binding SalirCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
