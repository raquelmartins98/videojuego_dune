<Window x:Class="Dune.Admin.Client.Views.CrearPartidaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Partida - Arrakan Dominion" 
        Height="280" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D0D0D">
    <Window.Resources>
        <Style x:Key="DuneButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2118"/>
            <Setter Property="Foreground" Value="#C9A227"/>
            <Setter Property="BorderBrush" Value="#C9A227"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A3728"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C9A227"/>
                                <Setter Property="Foreground" Value="#0D0D0D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="#1A1410" BorderBrush="#4A3728" BorderThickness="2" Margin="10">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Titulo -->
            <TextBlock Grid.Row="0" Text="◆ INICIAR NUEVA PARTIDA ◆" 
                       Foreground="#C9A227" FontFamily="Consolas" 
                       FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            
            <TextBlock Grid.Row="1" Text="Establecer nombre para la expedicion en Arrakan" 
                       Foreground="#8B7355" FontFamily="Consolas" 
                       FontSize="11" Margin="0,0,0,15"/>
            
            <!-- Label -->
            <TextBlock Grid.Row="2" Text="NOMBRE DE LA PARTIDA:" 
                       Foreground="#D4AF37" FontFamily="Consolas" 
                       FontSize="12" Margin="0,0,0,8"/>
            
            <!-- Input -->
            <TextBox Grid.Row="3" x:Name="NombreTextBox" 
                     Background="#0D0D0D" Foreground="#D4AF37"
                     BorderBrush="#4A3728" BorderThickness="1"
                     FontFamily="Consolas" FontSize="14"
                     Padding="10,8"/>
            
            <!-- Info -->
            <TextBlock Grid.Row="4" Text="El universo de Dune espera. La Especia debe fluir." 
                       Foreground="#4A3728" FontFamily="Consolas" 
                       FontSize="10" VerticalAlignment="Bottom" Margin="0,0,0,15"/>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="CREAR" Style="{StaticResource DuneButton}" 
                        Background="#228B22" Click="CrearButton_Click"/>
                <Button Content="CANCELAR" Style="{StaticResource DuneButton}" 
                        Background="#4A3728" Click="CancelarButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
