<Window x:Class="Dune.Admin.Client.Views.BestiarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Dune.Admin.Client.Converters"
        Title="Bestiario"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="900"
        Height="600"
        ShowInTaskbar="False"
        Background="#1A1410">
    
    <Window.Resources>
        <conv:TipoCriaturaToImageConverter x:Key="CriaturaImage"/>
        <conv:TipoEnclaveToImageConverter x:Key="EnclaveImage"/>
        <conv:TipoRecursoToImageConverter x:Key="RecursoImage"/>
        
        <Style x:Key="DuneButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2118"/>
            <Setter Property="Foreground" Value="#C9A227"/>
            <Setter Property="BorderBrush" Value="#C9A227"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A3728"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C9A227"/>
                                <Setter Property="Foreground" Value="#0D0D0D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="#0D0D0D" BorderBrush="#C9A227" BorderThickness="3" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#8B4513" BlurRadius="20" ShadowDepth="5" Opacity="0.8"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Border Grid.Row="0" Background="#1A1410" BorderBrush="#4A3728" BorderThickness="0,0,0,2" Padding="15,8">
                <TextBlock Text="◈ BESTIARIO ◈" Foreground="#C9A227" FontFamily="Consolas" FontSize="20" FontWeight="Bold" TextAlignment="Center"/>
            </Border>
            
            <Grid Grid.Row="1" Margin="10,5">
                <StackPanel x:Name="PanelCriaturas1">
                    <Border Background="#1A1410" BorderBrush="#4A3728" BorderThickness="1" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="CRIATURAS (1/2)" Foreground="#FF4500" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding InstanceGusano, Source={StaticResource CriaturaImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Gusano de Arena" Foreground="#C9A227" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="Depredador | Vida:100 | Atq:25" Foreground="#FF4500" FontSize="9"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="2,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding InstanceTigre, Source={StaticResource CriaturaImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Tigre Laza" Foreground="#C9A227" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="Depredador | Vida:80 | Atq:30" Foreground="#FF4500" FontSize="9"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding InstanceRoedoer, Source={StaticResource CriaturaImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Muad'Dib" Foreground="#C9A227" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="Recolector | Vida:50 | Atq:15" Foreground="#00CED1" FontSize="9"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Background="#1A1410" BorderBrush="#4A3728" BorderThickness="1" Padding="12">
                        <StackPanel>
                            <TextBlock Text="CRIATURAS (2/2)" Foreground="#FF4500" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding InstanceHalcon, Source={StaticResource CriaturaImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Halcon del Desierto" Foreground="#C9A227" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="Depredador | Vida:40 | Atq:20" Foreground="#FF4500" FontSize="9"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding InstanceAmeba, Source={StaticResource CriaturaImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Trucha de Arena" Foreground="#C9A227" FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="Depredador | Vida:60 | Atq:10" Foreground="#FF4500" FontSize="9"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="PanelCriaturas2" Visibility="Collapsed">
                    <Border Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="15">
                        <StackPanel>
                            <TextBlock Text="ACCIONES" Foreground="#FFD700" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="MOVER: Desplaza criaturas entre zonas" Foreground="#8B7355" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="ATACAR: Depredadores eliminan criaturas debiles" Foreground="#8B7355" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="EXTRAER: Recolectores obtienen recursos" Foreground="#8B7355" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="CONSTRUIR: Crea instalaciones en enclaves" Foreground="#8B7355" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="PanelRecursos">
                    <Border Background="#1A1410" BorderBrush="#4A3728" BorderThickness="1" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="RECURSOS" Foreground="#C9A227" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <Border Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="0,0,4,6">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding InstanceMelange, Source={StaticResource RecursoImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Melange" Foreground="#DAA520" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock Text="Comun | +10 por Ronda" Foreground="#8B7355" FontSize="9"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="0,0,4,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding InstanceNegro, Source={StaticResource RecursoImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Especia Negra" Foreground="#9370DB" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock Text="Legendaria | +5 por Ronda" Foreground="#8B7355" FontSize="9"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <Border Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="4,0,0,6">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding InstanceRosa, Source={StaticResource RecursoImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Especia Rosa" Foreground="#FF69B4" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock Text="Rara | +8 por Ronda" Foreground="#8B7355" FontSize="9"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="4,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding InstanceAgua, Source={StaticResource RecursoImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Agua" Foreground="#00CED1" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock Text="Vital | Escasez extrema" Foreground="#8B7355" FontSize="9"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Background="#1A1410" BorderBrush="#4A3728" BorderThickness="1" Padding="12">
                        <StackPanel>
                            <TextBlock Text="RECURSOS ADICIONALES" Foreground="#8B7355" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Materiales" Foreground="#8B7355" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="Necesario para construccion" Foreground="#8B7355" FontSize="9"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock Text="Energia" Foreground="#FFD700" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="Mantiene sistemas activos" Foreground="#8B7355" FontSize="9"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="PanelEnclaves">
                    <Border Background="#1A1410" BorderBrush="#4A3728" BorderThickness="1" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="ENCLAVES (1/2)" Foreground="#228B22" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding InstanceArena1, Source={StaticResource EnclaveImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Cuenca Experimental" Foreground="#C9A227" FontSize="10" FontWeight="Bold"/>
                                            <TextBlock Text="Investigacion" Foreground="#8B7355" FontSize="9"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding InstanceArena2, Source={StaticResource EnclaveImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Arrakeen" Foreground="#C9A227" FontSize="10" FontWeight="Bold"/>
                                            <TextBlock Text="Capital de Arrakis" Foreground="#8B7355" FontSize="9"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Background="#1A1410" BorderBrush="#4A3728" BorderThickness="1" Padding="12">
                        <StackPanel>
                            <TextBlock Text="ENCLAVES (2/2)" Foreground="#228B22" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding InstanceArena3, Source={StaticResource EnclaveImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Giedi Prime" Foreground="#C9A227" FontSize="10" FontWeight="Bold"/>
                                            <TextBlock Text="Industria y poder" Foreground="#8B7355" FontSize="9"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="6" Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding InstanceRocas, Source={StaticResource EnclaveImage}}" Width="36" Height="36" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Caladan" Foreground="#C9A227" FontSize="10" FontWeight="Bold"/>
                                            <TextBlock Text="Hogar Atreides" Foreground="#8B7355" FontSize="9"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="PanelInstalaciones">
                    <Border Background="#1A1410" BorderBrush="#4A3728" BorderThickness="1" Padding="15">
                        <StackPanel>
                            <TextBlock Text="INSTALACIONES" Foreground="#00CED1" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Aclimatacion" Foreground="#C9A227" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="Instala clones de criaturas compatibles. 20% probabilidad de generar una nueva criatura por Ronda." Foreground="#8B7355" FontSize="10" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Exhibicion" Foreground="#C9A227" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="Alberga criaturas para exhibicion publica. Atrae visitantes al enclave asociado." Foreground="#8B7355" FontSize="10" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#2D2118" BorderBrush="#4A3728" BorderThickness="1" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Recoleccion" Foreground="#C9A227" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="Genera automaticamente Muad'Dib clones para recolectar recursos." Foreground="#8B7355" FontSize="10" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="PanelConsejos">
                    <Border Background="#1A1410" BorderBrush="#4A3728" BorderThickness="1" Padding="15">
                        <StackPanel>
                            <TextBlock Text="CONSEJOS ESTRATEGICOS" Foreground="#FFD700" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="• Manten criaturas bien alimentadas para atraer visitantes" Foreground="#8B7355" FontSize="10" Margin="0,0,0,3"/>
                            <TextBlock Text="• Construye Exhibicion cerca de criaturas populares" Foreground="#8B7355" FontSize="10" Margin="0,0,0,3"/>
                            <TextBlock Text="• Usa Muad'Dib para Passive Income de especias" Foreground="#8B7355" FontSize="10" Margin="0,0,0,3"/>
                            <TextBlock Text="• Aclimatacion genera nuevas criaturas gratis" Foreground="#8B7355" FontSize="10" Margin="0,0,0,3"/>
                            <TextBlock Text="• Equilibra depredadores y recolectores" Foreground="#8B7355" FontSize="10" Margin="0,0,0,3"/>
                            <TextBlock Text="• Guarda frecuentemente para no perder progreso" Foreground="#8B7355" FontSize="10"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
            
            <Border Grid.Row="2" Background="#1A1410" BorderBrush="#4A3728" BorderThickness="0,2,0,0" Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="◀" Style="{StaticResource DuneButton}" Padding="12,5" Click="Anterior_Click"/>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="CRIATURAS" Style="{StaticResource DuneButton}" Padding="6,3" Margin="2" FontSize="9" Tag="Criaturas" Click="Categoria_Click"/>
                        <Button Content="RECURSOS" Style="{StaticResource DuneButton}" Padding="6,3" Margin="2" FontSize="9" Tag="Recursos" Click="Categoria_Click"/>
                        <Button Content="ENCLAVES" Style="{StaticResource DuneButton}" Padding="6,3" Margin="2" FontSize="9" Tag="Enclaves" Click="Categoria_Click"/>
                        <Button Content="INSTAL." Style="{StaticResource DuneButton}" Padding="6,3" Margin="2" FontSize="9" Tag="Instalaciones" Click="Categoria_Click"/>
                        <Button Content="CONSEJOS" Style="{StaticResource DuneButton}" Padding="6,3" Margin="2" FontSize="9" Tag="Consejos" Click="Categoria_Click"/>
                    </StackPanel>
                    
                    <Button Grid.Column="2" Content="▶" Style="{StaticResource DuneButton}" Padding="12,5" Click="Siguiente_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
