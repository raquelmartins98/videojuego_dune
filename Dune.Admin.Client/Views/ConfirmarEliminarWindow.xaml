<Window x:Class="Dune.Admin.Client.Views.ConfirmarEliminarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmar eliminación"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D0D0D"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="DuneButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2118"/>
            <Setter Property="Foreground" Value="#C9A227"/>
            <Setter Property="BorderBrush" Value="#C9A227"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A3728"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C9A227"/>
                                <Setter Property="Foreground" Value="#0D0D0D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#1A1410" BorderBrush="#C9A227" BorderThickness="2" Padding="30">
        <StackPanel>
            <TextBlock Text="⚠ CONFIRMAR ELIMINACIÓN ⚠" 
                       FontFamily="Consolas" FontSize="18" FontWeight="Bold" 
                       Foreground="#C9A227" TextAlignment="Center" Margin="0,0,0,20"/>
            
            <TextBlock x:Name="TextoMensaje" 
                       FontFamily="Consolas" FontSize="14" 
                       Foreground="#D4AF37" TextAlignment="Center" 
                       TextWrapping="Wrap" Width="300" Margin="0,0,0,25"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnSi" Content="✓ SÍ, ELIMINAR" 
                        Style="{StaticResource DuneButton}" 
                        Background="#8B0000" Foreground="White"
                        Padding="20,10" Margin="0,0,15,0"
                        Click="BtnSi_Click"/>
                <Button Content="✕ CANCELAR" 
                        Style="{StaticResource DuneButton}" 
                        Padding="20,10"
                        Click="BtnCancelar_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
